#include "mona2.dtsi"
#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>


/ {
    // トラックボール Y 軸を ⌘=/⌘- に離散化してズームを実現する
    //   mode=1   : 4 方向（X/Y いずれか強い方だけ発火）
    //   tick=80  : 80 カウント分動かすと 1 回発火（暴発防止のため少し鈍めに）
    //   threshold=5 : これ未満の微小移動は無視
    zip_keybind_zoom: zip_keybind_zoom {
        compatible = "zmk,input-processor-keybind";
        #input-processor-cells = <0>;
        bindings =
            <&none>,            // X+ (右): 未使用
            <&none>,            // X- (左): 未使用
            <&kp LG(MINUS)>,    // Y+ : ズームアウト
            <&kp LG(EQUAL)>;    // Y- : ズームイン
        mode = <1>;
        tick = <80>;
        threshold = <5>;
        wait-ms = <0>;
        tap-ms = <20>;
        track_remainders;
    };

    // トラックボールの動きをスクロールキーに離散化する (drift 抑制版)
    //   tick=30   : 30カウント蓄積で1段スクロール (連続感は zip_scroll_scaler 1/30 と同等)
    //   threshold=3 : ±2以下のdrift微小値を完全に切り捨てる
    //   mode=1   : 4方向（X/Y いずれか強い方だけ発火）
    zip_keybind_scroll: zip_keybind_scroll {
        compatible = "zmk,input-processor-keybind";
        #input-processor-cells = <0>;
        bindings =
            <&msc SCRL_LEFT>,   // X+ : 左スクロール (X反転で右に動かしたら左)
            <&msc SCRL_RIGHT>,  // X- : 右スクロール
            <&msc SCRL_DOWN>,   // Y+ : 下スクロール
            <&msc SCRL_UP>;     // Y- : 上スクロール
        mode = <1>;
        tick = <30>;
        threshold = <3>;
        wait-ms = <0>;
        tap-ms = <20>;
        track_remainders;
    };
};


&default_transform {
    col-offset = <6>;
};

&kscan0 {
        col-gpios
            = <&xiao_d 10 GPIO_ACTIVE_HIGH>
            , <&xiao_d 9 GPIO_ACTIVE_HIGH> 
            , <&xiao_d 8 GPIO_ACTIVE_HIGH> 
            , <&xiao_d 7 GPIO_ACTIVE_HIGH> 
            , <&gpio0 10 GPIO_ACTIVE_HIGH>
            ;
};


&pinctrl {
    spi0_default: spi0_default {    //通常時(SPI通信中)のピン構成
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>, //P0.05を指定(SCLK)
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,    //P0.04を指定(SDIOだからMOSI,MISO両方の役割を担う)
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {    //スリープ時のピン構成(省電力)
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };
    };
};


&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim"; //マイコンがnRFシリーズ
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;  //P0.09を指定(CS)

    trackball_central: trackball_central@0 {
        status = "okay";
        compatible = "pixart,pmw3610";  //トラボセンサ用のドライバとバインド
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; //P0.02を指定(MOTION)
        cpi = <600>;
        //swap-xy;
        invert-x; //COROPIT版ではコメントアウトを外す
        invert-y; //COROPIT版ではコメントアウトを外す
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
    };
};


// Overrides for the input listener node
&trackball_central_listener {
    status = "okay";
    device = <&trackball_central>;

    // Layer 3: トラックボールでスクロール (tick方式でドリフト抑制)
    //   zip_keybind_scroll で連続スクロールを離散化し、threshold=3でdriftをカット
    //   zip_xy_scaler 0 1 でXYポインタ移動を無効化（スクロール専用に）
    scroller {
        layers = <3>;
        input-processors =
            <&zip_keybind_scroll>,
            <&zip_xy_scaler 0 1>;
    };

    // Layer 6 (/-hold): トラックボール上下でズームイン/アウト
    //   zip_keybind_zoom で Y 軸の移動量を ⌘= / ⌘- に変換
    //   zip_xy_scaler 0 1 で XY を無効化してポインタが動かないようにする（本家ZMK使用時のワークアラウンド）
    zoomer {
        layers = <6>;
        input-processors =
            <&zip_keybind_zoom>,
            <&zip_xy_scaler 0 1>;
    };

};
